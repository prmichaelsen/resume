# Cloudflare API Configuration
# Copy this file to .env.cloudflare.local and fill in your values
# Get your API token from: https://dash.cloudflare.com/profile/api-tokens

# Cloudflare API Token (with Zone:Edit and DNS:Edit permissions)
CLOUDFLARE_API_TOKEN=your_api_token_here

# Cloudflare Account ID (found in dashboard URL or account settings)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# Domain to configure
CLOUDFLARE_DOMAIN=my-project.com

# Pages project name
CLOUDFLARE_PAGES_PROJECT=my-project

# GitHub repository (format: owner/repo)
GITHUB_REPO=user/my-project

# Production branch
PRODUCTION_BRANCH=main
